# HTTP
LISTEN_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:39476

# Runtime
DATA_DIR=/app/data
DB_PATH=/app/data/meshcore-live.db
LOG_LEVEL=info
TZ=America/Toronto
PUBLIC_MODE=true

# MQTT source
# Public examples run the synthetic fixture by default. Set true only after
# adding private MQTT credentials in your local .env.
MQTT_ENABLED=false
MQTT_BROKER_URL=wss://mqtt1.meshcore.ca:443/mqtt
MQTT_TOPIC=meshcore/#
MQTT_CLIENT_ID=meshcore-canada-live-map-local

# Auth mode: subscriber is preferred for analyzer/read-only full feed.
# Leave blank in the committed example. Put real credentials only in local .env.
MESHCORE_AUTH_MODE=subscriber
MQTT_USERNAME=
MQTT_PASSWORD=

# Optional future auth mode: key/JWT, only if broker permits analyzer subscription by key.
# Leave private keys blank in public examples.
MESHCORE_PUBLIC_KEY_HEX=
MESHCORE_PRIVATE_KEY_HEX=
MQTT_TOKEN_AUDIENCE=mqtt1.meshcore.ca

# Public group channel secrets used only to decode sanitized message bubble text.
# Comma-separate additional MeshCore channel secrets when needed.
# Never commit real channel secrets.
MESHCORE_CHANNEL_SECRETS=

# RF truth gates
STRICT_RF_ONLY=true
REQUIRE_RSSI_OR_SNR_FOR_EDGE=true
MAX_UNVERIFIED_EDGE_KM=150
ALLOW_LONG_TRACE_EDGES=true

# Initial map
DEFAULT_CENTER_LAT=56.1304
DEFAULT_CENTER_LNG=-106.3468
DEFAULT_ZOOM=3.5
DEFAULT_REGION=CANADA

# Live buffers
RECENT_PACKET_LIMIT=1000
RECENT_EDGE_EVENT_LIMIT=2000
WS_CLIENT_QUEUE_SIZE=512
MQTT_INGEST_QUEUE_SIZE=4096
PUBLIC_CACHE_REFRESH_SECONDS=10

# Public map allowlist from https://meshcore.ca/analyzer/intro/#iata-region-codes.
PUBLIC_IATAS=YYZ,YTZ,YOW,YHM,YKF,YXU,YOO,YKZ,YAM,YQT,YSB,YTS,YQG,YYB,YGK,YPQ,YTR,YHD,YPL,YND,YUL,YMX,YQB,YBG,YVO,YHU,YRJ,YGL,YSC,YTQ,YUY,YZV,YGP,YRQ,YVR,YYJ,YXX,YLW,YXS,YPR,YXT,YQQ,YCD,YYD,YDQ,YXJ,YYF,YCG,YKA,YXC,YBC,YYC,YEG,YMM,YQU,YQL,YXH,YQR,YXE,YPA,YWG,YBR,YTH,YDN,YPG,YFC,YSJ,YQM,ZBF,YHZ,YQY,YQI,YYG,YYT,YQX,YDF,YYR,YWK,YXY,YZF,YFB,YEV,YHY

# Optional config file for manual node/observer coordinate overrides
CONFIG_YAML=/app/data/config.yaml

# Optional fixture support
# Credential-free demo fixture. Clear this when using live MQTT.
FIXTURE_REPLAY_PATH=/app/examples/fixtures/synthetic-live.ndjson
FIXTURE_RECORD_ENABLED=false
